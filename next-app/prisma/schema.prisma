// Prisma Schema for UNFPA Knowledge Chat

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector", schema: "public")]
}

/// Deep research documents — the UNFPA institutional knowledge base.
model KnowledgeDocument {
  id        String   @id @default(cuid())
  vertical  String                           // e.g., 'UNFPA'
  title     String
  slug      String   @unique                 // e.g., 'unfpa-o-01-unfpa-in-plain-language'
  content   String   @db.Text               // Full markdown content
  summary   String?  @db.Text
  wordCount Int      @map("word_count")
  metadata  Json?                            // { topics, documentId, sourceFile, block, code, audience, tier }
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chunks    KnowledgeChunk[]
  pdfRecord PdfIngestRecord?

  @@index([vertical])
  @@map("knowledge_documents")
}

/// Chunked segments for vector search (~800-1200 words each).
model KnowledgeChunk {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  chunkIndex Int      @map("chunk_index")
  content    String   @db.Text
  tokenCount Int      @map("token_count")
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now()) @map("created_at")

  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("knowledge_chunks")
}

/// Tracks which PDF files have been ingested — for skip logic and change detection.
model PdfIngestRecord {
  id           String    @id @default(cuid())
  filename     String    @unique                // original filename (with spaces)
  slug         String    @unique                // normalized slug
  filePath     String    @map("file_path")
  sha256       String    @map("sha256")         // SHA-256 of file bytes
  documentId   String?   @unique @map("document_id")
  pageCount    Int       @map("page_count")
  wordCount    Int       @map("word_count")
  status       String    @default("success")   // success | failed | no-text
  errorMessage String?   @map("error_message") @db.Text
  ingestedAt   DateTime  @default(now()) @map("ingested_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  document     KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([sha256])
  @@map("pdf_ingest_records")
}
